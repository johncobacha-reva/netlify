rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Deals collection
    match /deals/{dealId} {
      function isValidDeal(data) {
        return data.address is string && data.address.size() <= 500 &&
               data.city is string && data.city.size() <= 100 &&
               data.propertyType in ['Retail', 'Industrial', 'Office', 'Multi-family', 'Land'] &&
               data.price is number && data.price >= 0 &&
               data.squareFootage is number && data.squareFootage >= 0 &&
               data.userId == request.auth.uid;
      }

      allow read: if isSignedIn(); // Users can view all deals for market analysis
      allow create: if isSignedIn() && isValidDeal(request.resource.data);
      allow update: if isOwner(resource.data.userId) && 
                      isValidDeal(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }

    // Market Trends (Read-only for users, managed per user session or system-wide)
    match /marketTrends/{trendId} {
      allow read: if isSignedIn();
      allow write: if false; // Only admins or system processes should update trends
    }
  }
}
